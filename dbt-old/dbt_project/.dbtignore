# dbt ignore file
# File dan folder yang dikecualikan dari dbt ls, dbt run, dll.

# Python virtual env
.venv/
venv/
env/

# dbt build artifacts (di-generate, jangan di-commit)
target/
dbt_packages/

# OS / editor
.DS_Store
*.swp
*.swo
__pycache__/
*.pyc

# Log
logs/
*.log

# Credential / secret (JANGAN pernah commit)
*.json
*.key
service_account*.json
